<odoo>
    <data>
        <record id="sports_facility_action" model="ir.actions.act_window">
            <field name="name">Facilities</field>
            <field name="res_model">sports.facility</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="sports_facility_view_list" model="ir.ui.view">
            <field name="name">sports.facility.list</field>
            <field name="model">sports.facility</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="sports_facility_view_form" model="ir.ui.view">
            <field name="name">sports.facility.form</field>
            <field name="model">sports.facility</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
