<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sports_amenity_list" model="ir.ui.view">
        <field name="name">sports.amenity.list</field>
        <field name="model">sports.amenity</field>
        <field name="arch" type="xml">
            <list string="Amenities">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_sports_amenity_form" model="ir.ui.view">
        <field name="name">sports.amenity.form</field>
        <field name="model">sports.amenity</field>
        <field name="arch" type="xml">
            <form string="Amenity">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sports_amenity" model="ir.actions.act_window">
        <field name="name">Amenities</field>
        <field name="res_model">sports.amenity</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
