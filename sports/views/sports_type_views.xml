<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sports_type_list" model="ir.ui.view">
        <field name="name">sports.type.list</field>
        <field name="model">sports.type</field>
        <field name="arch" type="xml">
            <list string="Sport Types">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_sports_type_form" model="ir.ui.view">
        <field name="name">sports.type.form</field>
        <field name="model">sports.type</field>
        <field name="arch" type="xml">
            <form string="Sport Type">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sports_type" model="ir.actions.act_window">
        <field name="name">Sport Types</field>
        <field name="res_model">sports.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

