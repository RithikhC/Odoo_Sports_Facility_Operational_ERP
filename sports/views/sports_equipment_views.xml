<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sports_equipment_list" model="ir.ui.view">
        <field name="name">sports.equipment.list</field>
        <field name="model">sports.equipment</field>
        <field name="arch" type="xml">
            <list string="Equipment">
                <field name="name"/>
                <field name="facility_id"/>
                <field name="sport_type_id"/>
                <field name="rental_price"/>
                <field name="stock_quantity"/>
            </list>
        </field>
    </record>

    <record id="view_sports_equipment_form" model="ir.ui.view">
        <field name="name">sports.equipment.form</field>
        <field name="model">sports.equipment</field>
        <field name="arch" type="xml">
            <form string="Equipment">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Equipment Name"/></h1>
                    </div>
                    <group>
                        <field name="facility_id"/>
                        <field name="sport_type_id"/>
                        <field name="rental_price"/>
                        <field name="stock_quantity"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sports_equipment" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="res_model">sports.equipment</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

